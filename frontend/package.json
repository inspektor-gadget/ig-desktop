{
	"name": "@inspektor-gadget/frontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"main": "dist-lib/ig-frontend.js",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"build:single-env": "VITE_APP_MODE=single-env vite build",
		"build:demo": "VITE_APP_MODE=demo vite build",
		"build:demo:subdir": "VITE_APP_MODE=demo VITE_BASE_PATH=/igd-demo vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"build:dev": "vite build --minify false --mode development",
		"build:lib": "vite build --config vite.lib.config.ts",
		"build:lib:watch": "vite build --config vite.lib.config.ts --watch"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "2.60.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/container-queries": "^0.1.1",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/postcss": "^4.1.18",
		"@tailwindcss/typography": "^0.5.19",
		"@types/d3": "^7.4.3",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^25.8.0",
		"@xyflow/svelte": "^1.5.2",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.16.0",
		"globals": "^17.3.0",
		"prettier": "^3.7.4",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.55.8",
		"svelte-check": "^4.3.4",
		"tailwindcss": "^4.2",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.59.3",
		"vite": "^8.0.12"
	},
	"dependencies": {
		"@dagrejs/dagre": "^3.0.0",
		"@tailwindcss/vite": "^4.1.18",
		"@wailsio/runtime": "3.0.0-alpha.79",
		"d3": "^7.9.0",
		"dompurify": "^3.4.5",
		"i18next": "^23.16.8",
		"i18next-browser-languagedetector": "^8.0.2",
		"js-yaml": "^4.1.1",
		"marked": "^18.0.2",
		"monaco-editor": "^0.55.1",
		"posthog-js": "^1.373.4"
	},
	"overrides": {
		"cookie": "1.1.1"
	}
}
